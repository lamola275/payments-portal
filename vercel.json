{
  "buildCommand": "cd artifacts/react-app && pnpm run build",
  "outputDirectory": "artifacts/react-app/build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
